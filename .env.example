# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=ratiebareeng
DB_PASSWORD=
DB_NAME=gaborone_reserve

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@gaboronereserve.bw

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# AWS S3 Configuration
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=gaborone-reserve-media

# Payment Gateway (DPO PayGate)
DPO_COMPANY_TOKEN=your_dpo_company_token
DPO_SERVICE_TYPE=your_service_type
DPO_PAYMENT_URL=https://secure.paygate.co.bw/payweb3/process.trans
DPO_QUERY_URL=https://secure.paygate.co.bw/payweb3/query.trans

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# App Configuration
APP_NAME=Gaborone Game Reserve
APP_URL=https://gaboronereserve.bw
FRONTEND_URL=https://app.gaboronereserve.bw
